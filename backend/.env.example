# ─────────────────────────────────────────────────────────────
# GigShield Backend — Environment Variables
# Copy to .env and fill in real values before running locally
# or docker-compose. Docker-compose overrides DATABASE_URL,
# REDIS_URL, and ML_SERVICE_URL automatically.
# ─────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────
DATABASE_URL=postgresql://gigshield:gigshield123@postgres:5432/gigshield
POSTGRES_USER=gigshield
POSTGRES_PASSWORD=gigshield123
POSTGRES_DB=gigshield

# ── Redis ──────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Application ────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── JWT ────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=7d
ADMIN_JWT_SECRET=

# ── Twilio (SMS OTP) ───────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=+1234567890

# ── Razorpay (Payments + AutoPay) ─────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# The contact number of the business bank account for payouts
RAZORPAY_ACCOUNT_NUMBER=

# ── External Data APIs ─────────────────────────────────────────
OPENWEATHER_API_KEY=
# Central Pollution Control Board — AQI feed
CPCB_API_KEY=
NEWS_API_KEY=

# ── Internal Services ──────────────────────────────────────────
ML_SERVICE_URL=http://ml-service:8001
FRONTEND_URL=http://localhost:5173

# ── Bull Queue (Redis-backed) ──────────────────────────────────
# Prefix for queue job keys in Redis (optional, defaults to 'bull')
BULL_QUEUE_PREFIX=gigshield

# ── CORS ───────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
